{
  "name": "woosign-system",
  "version": "0.1.0",
  "description": "WooBottle 'Paper & Ink' design system — cross-platform React Native + Web components (cream canvas, ink surfaces, ember CTAs, ceremonial gold).",
  "keywords": [
    "react",
    "react-native",
    "design-system",
    "ui-components",
    "cross-platform",
    "woobottle",
    "pretendard",
    "tokens"
  ],
  "license": "UNLICENSED",
  "author": "wooBottle",
  "homepage": "https://github.com/woobottle/woosign-system#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/woobottle/woosign-system.git"
  },
  "bugs": {
    "url": "https://github.com/woobottle/woosign-system/issues"
  },
  "main": "lib/commonjs/index.js",
  "module": "lib/module/index.js",
  "types": "lib/typescript/index.d.ts",
  "react-native": "src/index.ts",
  "source": "src/index.ts",
  "files": [
    "src",
    "lib",
    "react-native.config.js",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__",
    "!**/*.stories.tsx",
    "!**/*.stories.js",
    "!**/*.stories.js.map",
    "!**/*.stories.d.ts",
    "!**/*.stories.d.ts.map",
    "!**/*.map",
    "!**/*.test.ts",
    "!**/*.test.tsx",
    "!**/*.test.js",
    "!**/*.test.d.ts",
    "!jest.setup.ts",
    "!jest.config.js",
    "!src/examples",
    "!lib/commonjs/examples",
    "!lib/module/examples",
    "!lib/typescript/examples",
    "!lib/commonjs/assets",
    "!lib/module/assets",
    "!lib/typescript/assets"
  ],
  "sideEffects": false,
  "scripts": {
    "prepare": "bob build",
    "build": "bob build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "test": "jest",
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "start": "react-native start",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "storybook:native:generate": "sb-rn-get-stories --config-path ./.storybook-native",
    "storybook:native:ios": "STORYBOOK_ENABLED=true react-native run-ios",
    "storybook:native:android": "STORYBOOK_ENABLED=true react-native run-android"
  },
  "peerDependencies": {
    "react": ">=17.0.0",
    "react-native": ">=0.78.0"
  },
  "peerDependenciesMeta": {
    "react-native": {
      "optional": true
    }
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@babel/preset-env": "^7.20.0",
    "@babel/runtime": "^7.20.0",
    "@gorhom/bottom-sheet": "^5.2.8",
    "@react-native-async-storage/async-storage": "^2.1.0",
    "@react-native-community/cli": "15.1.3",
    "@react-native/babel-preset": "0.78.3",
    "@react-native/eslint-config": "^0.72.2",
    "@react-native/metro-config": "0.78.3",
    "@storybook/addon-a11y": "^10.2.0",
    "@storybook/react": "^10.2.0",
    "@storybook/react-native": "^10.1.11",
    "@storybook/react-vite": "^10.2.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@tsconfig/react-native": "^3.0.0",
    "@types/jest": "^30.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/react-test-renderer": "^18.0.0",
    "babel-jest": "^29.2.1",
    "eslint": "^8.19.0",
    "jest": "^29.2.1",
    "jest-environment-jsdom": "^30.3.0",
    "prettier": "^2.4.1",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-native": "0.78.3",
    "react-native-builder-bob": "^0.23.0",
    "react-native-gesture-handler": "^2.20.0",
    "react-native-reanimated": "^3.16.0",
    "react-native-safe-area-context": "^5.6.2",
    "react-native-svg": "^15.8.0",
    "react-test-renderer": "19.0.0",
    "storybook": "^10.2.0",
    "ts-jest": "^29.4.9",
    "typescript": "^5.0.0",
    "vite": "^5.0.0"
  },
  "engines": {
    "node": ">=16"
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "exclude": "**/{__tests__,__fixtures__,__mocks__,examples}/**,**/*.stories.{ts,tsx},**/*.test.{ts,tsx},assets/**",
    "targets": [
      "commonjs",
      "module",
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  }
}
